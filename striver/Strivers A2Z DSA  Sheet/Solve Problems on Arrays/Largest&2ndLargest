using namespace std;

int main() {
    int arr[] = {3, 2, 1, 5, 2};
    int n = 5;

    int firstlarge = INT_MIN;
    int seclarge = INT_MIN;

    // Find largest
    for(int i = 0; i < n; i++) {
        if(arr[i] > firstlarge) {
            firstlarge = arr[i];
        }
    }

    // Find second largest
    for(int i = 0; i < n; i++) {
        if(arr[i] > seclarge && arr[i] < firstlarge) {
            seclarge = arr[i];
        }
    }

    cout << seclarge;
}








