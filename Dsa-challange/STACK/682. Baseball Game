Problem kya hai?
Ek baseball game mein runs record hote hain. Tumhe ek list di jaati hai operations ki:
Input          Matlab
"5"            5 runs score karo 
"3"            3 runs score karo
"+"            Last 2 scores ka sum add karo
"D"            Last score ka double add karo 
"C"            Last score cancel/delete karo

Goal: Saare valid scores ka total sum nikalo.










class Solution {
public:
    int calPoints(vector<string>& operations) {
        vector<int> arr;
        int n = operations.size();
        for (int i=0; i<n; i++){
            if (operations[i]=="+"){
                arr.push_back(arr[arr.size()-1]+arr[arr.size()-2]);
            }
            else if(operations[i]=="C"){
                arr.pop_back();
            }
            else if(operations[i]=="D"){
                arr.push_back(2*(arr[arr.size()-1]));
            }
            else {
                arr.push_back(stoi(operations[i]));
            }
        }
        int output=0;
        for (int a:arr){
            output+=a;
        }
        return output;
    }
};















