class Solution {
public:
    int calPoints(vector<string>& ops) {
        stack<int> st;  // int — kyunki numbers store karenge

        for(int i = 0; i < ops.size(); i++) {

            if(ops[i] == "C") {
                st.pop();  // last score cancel

            } else if(ops[i] == "D") {
                st.push(2 * st.top());  // last ka double

            } else if(ops[i] == "+") {
                int top1 = st.top(); st.pop();
                int top2 = st.top();
                st.push(top1);           // top1 wapas push
                st.push(top1 + top2);    // sum push

            } else {
                st.push(stoi(ops[i]));  // normal number — string to int
            }
        }

        // ab stack mein saare scores hain, sum nikalo
        int sum = 0;
        while(!st.empty()) {
            sum += st.top();
            st.pop();
        }
        return sum;
    }
};
