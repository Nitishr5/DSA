 

Example 1:

Input: nums = [1,3,4,2,2]
Output: 2



class Solution {
public:
    int findDuplicate(vector<int>& nums) {
        sort(nums.begin(),nums.end());
        for(int i=0;i<nums.size()-1;i++){
            if(nums[i]==nums[i+1]){
                return nums[i];
            }
        }
        return -1;
    }
};      TIME-COMPLAXITY====>> O(NlogN).



