int findDuplicate(vector<int>& nums) {
    unordered_set<int> s;
    for(int num : nums){
        if(s.find(num) != s.end()){
            return num;
        }
        s.insert(num);
    }
    return -1;
}




class Solution {
public:
    int findDuplicate(vector<int>& nums) {
        while(nums[0]!=nums[nums[0]]){
            swap(nums[0],nums[nums[0]]);
        }
        return nums[0];
    }
};
