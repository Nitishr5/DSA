Input: s = "abba"
Output: true
Explanation: "abba" reads the same forwards and backwards, so it is a palindrome.
Input: s = "abc" 
Output: false
Explanation: "abc" does not read the same forwards and backwards, so it is not a palindrome.








class Solution {
  public:
    bool isPalindrome(string& s) {
        // code here
        int n=s.size();
        
        int st=0,end=n-1;
        string s2=s;
        
        while(st<end){
            if(s[st]!=s[end]){
                return false;
            }
            st++;
            end--;
            
        }
       return true;
    }
};
